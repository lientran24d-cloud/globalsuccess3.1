        // BỘ LỌC AI SƯ PHẠM - SINH LỜI GIẢI THÍCH CHI TIẾT
        function buildDynamicExplanation(qObj) {
            let ans = String(qObj.correct_answer || "").trim();
            let ansLower = ans.toLowerCase().replace(/[^a-z0-9\s]/g, '');
            let qText = String(qObj.question || "").replace(/<[^>]*>?/gm, '').trim();
            let dbExp = String(qObj.explanation || "").replace(/<[^>]*>?/gm, '').trim();

            let fullSentence = qText;
            if (qText.includes('___') || qText.includes('...')) {
                // Tách ô điền từ nhiều ô
                let parts = ans.split('|');
                let i = 0;
                fullSentence = qText.replace(/(_{2,}|\.{2,})/g, () => {
                    let val = parts[i++] || ans;
                    return `<b class="text-bamboo-700 bg-bamboo-100 px-2 rounded">[ ${val} ]</b>`;
                });
            } else {
                fullSentence = `${qText} ➔ <b class="text-bamboo-700">${ans}</b>`;
            }

            let step1 = dbExp !== "" ? dbExp : `Từ "<b>${ans.replace(/\|/g, ' và ')}</b>" là lựa chọn chính xác nhất.`;
            let step2 = `- <b>${ans.replace(/\|/g, ' / ')}</b> là từ khóa trọng tâm cần ghi nhớ.`;
            let step3 = `Đây là điểm ngữ pháp quan trọng trong Unit 2: Our Names.`;
            let step5 = `<i>Let's read aloud!</i> (Hãy đọc to câu hoàn chỉnh để ghi nhớ nhé!)`;

            // Tự động phân tích ngữ nghĩa
            if (ansLower.includes('name') || qText.toLowerCase().includes('name')) {
                step2 = `- <b>Name</b> /neɪm/: Tên<br/>- <b>Your</b>: Của bạn<br/>- <b>My</b>: Của mình`;
                step3 = `Mẫu câu hỏi và trả lời tên: <b>What's your name? ➔ My name's + [tên].</b>`;
                step5 = `<i>My name's Peter.</i> (Tên mình là Peter.)`;
            } else if (ansLower.includes('spell') || qText.toLowerCase().includes('spell')) {
                step2 = `- <b>Spell</b> /spel/: Đánh vần`;
                step3 = `Mẫu câu yêu cầu đánh vần tên: <b>How do you spell your name?</b>`;
                step5 = `<i>How do you spell "cat"? ➔ C-A-T.</i>`;
            } else if (ansLower.includes('old') || qText.toLowerCase().includes('old')) {
                step2 = `- <b>Old</b> /əʊld/: Tuổi, già<br/>- <b>Years old</b>: Tuổi`;
                step3 = `Mẫu câu hỏi tuổi: <b>How old are you?</b> (Bạn bao nhiêu tuổi?)`;
                step5 = `<i>I'm eight years old.</i> (Mình 8 tuổi.)`;
            } else if (ansLower.includes('meet') || qText.toLowerCase().includes('meet')) {
                step2 = `- <b>Meet</b> /miːt/: Gặp gỡ<br/>- <b>Nice</b> /naɪs/: Tốt, vui`;
                step3 = `Mẫu câu chào khi gặp mặt: <b>Nice to meet you.</b> (Rất vui được gặp bạn.)`;
                step5 = `<i>Nice to meet you, too.</i> (Mình cũng rất vui được gặp bạn.)`;
            } else if (ansLower.includes('friend') || qText.toLowerCase().includes('friend')) {
                step2 = `- <b>Friend</b> /frend/: Người bạn`;
                step3 = `Dùng để giới thiệu bạn bè: <b>This is my friend, [tên].</b>`;
                step5 = `<i>This is my friend, Mary.</i> (Đây là bạn của mình, Mary.)`;
            } else if (ansLower.match(/^(six|seven|eight|nine|ten)$/) || qText.match(/(six|seven|eight|nine|ten)/i)) {
                step2 = `- Các số đếm tiếng Anh: <b>six</b> (6), <b>seven</b> (7), <b>eight</b> (8), <b>nine</b> (9), <b>ten</b> (10).`;
                step3 = `Được dùng để nói về tuổi tác hoặc đếm số lượng.`;
                step5 = `<i>I am nine years old.</i> (Mình 9 tuổi.)`;
            } else if (ansLower.match(/^(my|your|our|their|his|her|its)$/i)) {
                step2 = `- Đây là <b>Tính từ sở hữu</b>, đứng trước danh từ để chỉ sự sở hữu.`;
                step3 = `Ví dụ: my name (tên của tôi), your name (tên của bạn), her name (tên cô ấy).`;
                step5 = `<i>Her name is Linh.</i> (Tên cô ấy là Linh.)`;
            } else if (ansLower.match(/^(is|am|are)$/i) || ans.includes('|')) {
                step2 = `- Động từ "to be": <b>am, is, are</b> (thì, là, ở).`;
                step3 = `Quy tắc: <b>I + am</b> | <b>You/We/They/Số nhiều + are</b> | <b>He/She/It/Số ít + is</b>.`;
                step5 = `<i>I am Lan. She is Mary. They are friends.</i>`;
            }

            return `
                <div class="space-y-2 mt-2 text-[15px] leading-relaxed">
                    <p><b>① Vì sao đáp án đúng:</b> ${step1}</p>
                    <p><b>② Nghĩa từ vựng:</b><br/> ${step2}</p>
                    <p><b>③ Mẫu câu / Ngữ pháp:</b> ${step3}</p>
                    <p><b>④ Câu hoàn chỉnh / Dịch nghĩa:</b><br/> ${fullSentence}</p>
                    <p><b>⑤ Ví dụ tương tự:</b> ${step5}</p>
                </div>
            `;
        }

        // TẢI BÀI TẬP - ĐỌC ĐÚNG DỮ LIỆU UNIT 2
        async function fetchExercises() {
