                // =========================================================================
                let translatedExName = exName.replace(/Exercise\s+(\d+):/gi, "Bài $1:");
                const dict = {
                    "Look at the photo and complete the word with missing letter n or m.": "Nhìn ảnh và điền chữ n hoặc m còn thiếu.",
                    "Complete the sentences with the words in the box.": "Điền từ trong danh sách để hoàn thành câu.",
                    "Complete the sentences.": "Hoàn thành các câu sau.",
                    "Choose the odd one out.": "Chọn từ khác loại.",
                    "Give the possessive adjectives.": "Điền tính từ sở hữu tương ứng.",
                    "Reorder the letters to have the correct words.": "Sắp xếp chữ cái thành từ đúng.",
                    "Reorder the letters.": "Sắp xếp chữ cái thành từ đúng.",
                    "Write the correct numbers.": "Viết số tiếng Anh tương ứng.",
                    "Read and match.": "Đọc và nối câu phù hợp.",
                    "Give the correct form of to be: is/ am/ are.": "Điền động từ to be (am, is, are) thích hợp.",
                    "Choose the best option to complete the sentence.": "Chọn đáp án đúng nhất.",
                    "Choose the best option.": "Chọn đáp án đúng nhất.",
                    "Read and number the sentences in the correct order.": "Đọc và đánh số để sắp xếp đoạn hội thoại.",
                    "Choose the best response.": "Chọn câu đáp lại phù hợp nhất.",
                    "Make questions and answers.": "Viết câu hỏi và câu trả lời theo mẫu.",
                    "Reorder the words to have correct sentences.": "Sắp xếp các từ thành câu hoàn chỉnh."
                };
                for (let eng in dict) {
                    translatedExName = translatedExName.replace(new RegExp(eng.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), "gi"), dict[eng]);
                }

                exBlock.innerHTML = `<h3 class="text-xl font-extrabold text-sunny-600 mb-5 border-b-2 border-slate-200 pb-3 flex items-center gap-2"><span>📋</span> ${translatedExName}</h3>`;

                // Render Word Bank (Tàng hình từ vựng)
                if (questions.some(q => q.use_word_bank)) {
                    let words = [];
                    questions.forEach(q => { if(q.use_word_bank && q.correct_answer) words = words.concat(q.correct_answer.split('|').join(',').split(',').map(w => w.trim())); });
                    words.sort(() => Math.random() - 0.5); 
                    wordBanksData[exName] = words;
                    
                    const wbHtml = `
                        <div class="bg-white border-2 border-magic-200 p-4 rounded-xl mb-6 shadow-sm sticky top-4 z-10">
                            <div class="font-bold text-magic-600 text-sm mb-2">🏷️ CHỌN TỪ ĐỂ ĐIỀN:</div>
