                    const qFlex = document.createElement('div');
                    qFlex.className = isEx4 ? 'flex flex-col items-center w-full' : 'flex gap-3 items-start w-full';

                    const qNum = document.createElement('div');
                    qNum.className = isEx4 ? 'font-bold text-slate-500 mb-2' : 'font-bold text-white bg-slate-300 w-8 h-8 rounded-full flex items-center justify-center shrink-0 mt-0.5';
                    qNum.innerText = isEx4 ? `${index + 1}.` : index + 1;
                    
                    const qContent = document.createElement('div');
                    qContent.className = 'w-full text-lg font-medium text-slate-800 leading-relaxed';
                    let imageHtml = q.image_url ? `<div class="w-full flex justify-center mb-3"><img src="${q.image_url}" class="h-32 object-contain rounded-lg"></div>` : '';
                    let qText = q.question.replace(/^\d+\.\s*/, '');
                    
                    // Dịch một số câu lệnh dính liền trong nội dung câu hỏi
                    qText = qText.replace(/Choose the odd one out:/gi, 'Chọn từ khác loại:');

                    // TRẮC NGHIỆM ĐƠN LỰA CHỌN
                    if (q.question_type === 'multiple_choice' || q.question_type === 'true_false') {
                        let options = q.options;
                        const optionsDiv = document.createElement('div');
                        optionsDiv.className = options.length === 4 ? 'grid grid-cols-1 sm:grid-cols-2 gap-3 w-full' : 'space-y-3 w-full';
                        
                        options.forEach(opt => {
                            const btn = document.createElement('button');
                            btn.type = 'button';
                            btn.className = `option-btn w-full text-left p-3 rounded-xl border-2 border-slate-200 bg-slate-50 font-bold text-base text-slate-600 flex items-center gap-3`;
                            btn.setAttribute('data-qid', q.id);
                            btn.setAttribute('data-optid', opt.id);
                            btn.innerHTML = `<span class="inline-block min-w-[2.5rem] px-3 h-8 rounded-full bg-white text-slate-500 flex items-center justify-center border border-slate-300 shrink-0 indicator-circle text-sm">${opt.id}</span> <span>${opt.text}</span>`;
                            btn.onclick = () => handleChoiceAnswer(q.id, opt.id);
                            optionsDiv.appendChild(btn);
                        });
                        qContent.innerHTML = `${imageHtml}<div class="mb-4">${qText}</div>`;
                        qContent.appendChild(optionsDiv);
