                    feedbackDiv.id = `feedback-${q.id}`;
                    feedbackDiv.className = 'mt-4 hidden w-full text-left';

                    if (!isEx4) qFlex.appendChild(qNum);
                    else qContent.insertBefore(qNum, qContent.firstChild);
                    
                    qFlex.appendChild(qContent);
                    qItem.appendChild(qFlex);
                    qItem.appendChild(feedbackDiv);
                    itemsContainer.appendChild(qItem);
                });
                exBlock.appendChild(itemsContainer);
                container.appendChild(exBlock);
            }
        }

        // BẢO VỆ LỖI NULL: Chỉ gọi className khi indicator tồn tại
        window.handleChoiceAnswer = function(qId, selectedOptId) {
            userAnswers[qId] = selectedOptId;

            const allButtonsInQuestion = document.querySelectorAll(`button[data-qid="${qId}"]`);
            allButtonsInQuestion.forEach(btn => {
                const optId = btn.getAttribute('data-optid');
                const indicator = btn.querySelector('.indicator-circle');
                if (optId === selectedOptId) {
                    btn.className = 'option-btn w-full text-left p-3 rounded-xl border-2 bg-sunny-50 border-sunny-400 text-sunny-700 font-bold text-base flex items-center gap-3 shadow-sm';
                    if (indicator) indicator.className = 'inline-block min-w-[2.5rem] px-3 h-8 rounded-full bg-sunny-400 text-white flex items-center justify-center border border-sunny-400 shrink-0 indicator-circle font-bold text-sm';
                } else {
                    btn.className = 'option-btn w-full text-left p-3 rounded-xl border-2 border-slate-200 bg-slate-50 font-bold text-base text-slate-500 flex items-center gap-3 hover:bg-slate-100 transition';
                    if (indicator) indicator.className = 'inline-block min-w-[2.5rem] px-3 h-8 rounded-full bg-white text-slate-400 flex items-center justify-center border border-slate-300 shrink-0 indicator-circle font-bold text-sm';
                }
            });

            updateAnswerCount();
            saveProgress(); 
        }

        window.appendReorderWord = function(qId, word, wIdx) {
            const btn = document.getElementById(`reorder-btn-${qId}-${wIdx}`);
            if (btn.classList.contains('hidden')) return; 
            btn.classList.add('hidden');
            const input = document.getElementById(`input-ex-${qId}-0`);
            input.value = input.value.trim() === "" ? word : input.value + " " + word;
            handleMultiInput(qId);
        }

        window.clearReorder = function(qId) {
            document.getElementById(`input-ex-${qId}-0`).value = "";
            document.querySelectorAll(`.reorder-btn-${qId}`).forEach(b => b.classList.remove('hidden'));
            handleMultiInput(qId);
        }

        window.fillWordBank = function(exName, word) {
            const questions = exercisesData.filter(q => q.exercise_name === exName);
            for (let q of questions) {
                const inputs = document.querySelectorAll(`input[data-qid="${q.id}"]`);
                let filled = false;
                for (let input of inputs) {
                    if (input.classList.contains('word-bank-target') && input.value.trim() === "" && !input.disabled) {
                        input.value = word;
                        handleMultiInput(q.id);
                        filled = true; break;
                    }
                }
                if (filled) break;
            }
        }

        function updateWordBankUI(exName) {
            const container = document.querySelector(`.word-bank-words[data-exname="${exName}"]`);
            if (!container) return;
            const questions = exercisesData.filter(q => q.exercise_name === exName);
            let usedWords = [];
            questions.forEach(q => {
                const inputs = document.querySelectorAll(`input[data-qid="${q.id}"]`);
                inputs.forEach(inp => { if (inp.value.trim() !== "") usedWords.push(inp.value.trim().toLowerCase()); });
            });

            let tempUsed = [...usedWords];
            let originalWords = wordBanksData[exName];

            container.innerHTML = originalWords.map(w => {
                const wordLower = w.toLowerCase();
                const indexInUsed = tempUsed.indexOf(wordLower);
                if (indexInUsed !== -1) {
                    tempUsed.splice(indexInUsed, 1);
                    return ``; 
                } else {
                    let safeW = w.replace(/"/g, '&quot;');
                    return `<button type="button" data-word="${safeW}" onclick="fillWordBank('${exName}', this.getAttribute('data-word'))" class="bg-magic-50 text-magic-700 hover:bg-magic-200 hover:scale-105 transition px-4 py-2 rounded-lg border border-magic-300 font-bold shadow-sm">${w}</button>`;
                }
            }).join('');
        }

        window.handleMultiInput = function(qId) {
            const inputs = document.querySelectorAll(`input[data-qid="${qId}"]`);
            let vals = [];
            let hasValue = false;
            inputs.forEach(inp => {
                vals.push(inp.value.trim());
                if(inp.value.trim() !== "") hasValue = true;
            });
            
            if (hasValue) {
                userAnswers[qId] = vals.join('|');
            } else {
                delete userAnswers[qId];
            }
            
            const q = exercisesData.find(e => e.id == qId);
            if (q && q.use_word_bank) updateWordBankUI(q.exercise_name);
            
            updateAnswerCount(); saveProgress(); 
        }

        function updateAnswerCount() {
            const count = Object.keys(userAnswers).length;
            document.getElementById('answered-display').innerText = count;
            if (count === exercisesData.length) document.getElementById('submit-warning').classList.add('hidden');
        }

        function normalizeString(str) { return String(str || "").replace(/\|/g, '').toLowerCase().replace(/[^a-z0-9]/g, ''); }

        function saveProgress() { localStorage.setItem(STORAGE_KEY, JSON.stringify({ name: document.getElementById('student-name').value, answers: userAnswers })); }
        
        function loadProgress() {
            const savedData = localStorage.getItem(STORAGE_KEY);
            if (savedData) {
                const progressObj = JSON.parse(savedData);
                if (progressObj.name) document.getElementById('student-name').value = progressObj.name;
                if (progressObj.answers) {
                    userAnswers = progressObj.answers;
                    for (const [qId, ans] of Object.entries(userAnswers)) {
                        const q = exercisesData.find(e => e.id == qId);
                        if (!q) continue;
                        if (q.question_type === 'input') {
                            let vals = ans.split('|');
                            const inputs = document.querySelectorAll(`input[data-qid="${qId}"]`);
                            inputs.forEach((inp, idx) => { if (vals[idx]) inp.value = vals[idx]; });
                            
                            if (q.exercise_name && (q.exercise_name.includes('Exercise 15') || q.exercise_name.includes('Exercise 5') || q.exercise_name.includes('Reorder'))) {
                                ans.replace(/\|/g, ' ').split(' ').forEach(w => {
                                    for (let btn of document.querySelectorAll(`.reorder-btn-${qId}:not(.hidden)`)) {
                                        if (btn.innerText === w) { btn.classList.add('hidden'); break; }
                                    }
                                });
                            }
                        } else {
                            const btn = document.querySelector(`button[data-qid="${qId}"][data-optid="${ans}"]`);
                            if (btn) {
                                btn.className = 'option-btn w-full text-left p-3 rounded-xl border-2 bg-sunny-50 border-sunny-400 text-sunny-700 font-bold text-base flex items-center gap-3 shadow-sm';
                                const indicator = btn.querySelector('.indicator-circle');
                                if (indicator) indicator.className = 'inline-block min-w-[2.5rem] px-3 h-8 rounded-full bg-sunny-400 text-white flex items-center justify-center border border-sunny-400 shrink-0 indicator-circle font-bold text-sm';
                            }
                        }
                    }
                    updateAnswerCount();
                    for (const exName of Object.keys(wordBanksData)) updateWordBankUI(exName);
                }
            }
        }
        window.resetAllProgress = function() { if(confirm("Em có muốn làm lại từ đầu không?")) { localStorage.removeItem(STORAGE_KEY); location.reload(); } }

        window.submitLesson = async function() {
            const nameContainer = document.getElementById('name-container');
            const studentNameInput = document.getElementById('student-name');
            const studentName = studentNameInput.value.trim();
            const warning = document.getElementById('submit-warning');
            
            if (!studentName) {
                nameContainer.classList.add('ring-4', 'ring-red-300', 'animate-bounce', 'bg-red-50');
                setTimeout(() => nameContainer.classList.remove('animate-bounce'), 1000);
                warning.innerHTML = `⚠️ <b>Em phải nhập tên của mình ở góc trên cùng trước khi nộp bài nhé!</b>`;
                warning.classList.remove('hidden'); window.scrollTo({ top: 0, behavior: 'smooth' }); studentNameInput.focus();
                return;
            } else nameContainer.classList.remove('ring-4', 'ring-red-300', 'bg-red-50');

            const answeredCount = Object.keys(userAnswers).length;
            if (answeredCount < exercisesData.length) {
                warning.innerHTML = `⚠️ Em mới làm <b>${answeredCount}/${exercisesData.length}</b> câu. Hãy hoàn thành nốt nhé!`;
                warning.classList.remove('hidden'); window.scrollTo({ top: 0, behavior: 'smooth' }); return; 
            }

            const btn = document.getElementById('main-submit-btn');
            btn.innerHTML = `<div class="spinner border-t-white w-6 h-6 mr-2"></div> Đang chấm điểm...`;
            btn.disabled = true; warning.classList.add('hidden');

            let score = 0; let mistakesList = [];
            
            exercisesData.forEach(ex => {
                try {
                    const qItem = document.getElementById(`q-item-${ex.id}`);
                    if (!qItem) return;
                    const feedbackDiv = document.getElementById(`feedback-${ex.id}`);
                    let isCorrect = false; let correctDisplay = ex.correct_answer || "";

                    if (ex.question_type === 'input') {
                        const inputs = document.querySelectorAll(`input[data-qid="${ex.id}"]`);
                        if (inputs.length > 0) {
                            inputs.forEach(inp => inp.disabled = true); 
                            const userStr = userAnswers[ex.id] || "";
                            isCorrect = normalizeString(userStr) === normalizeString(ex.correct_answer);
                            
                            inputs.forEach(input => {
                                if (isCorrect) {
                                    input.classList.add('bg-bamboo-100', 'text-bamboo-700', 'border-bamboo-500');
                                    input.classList.remove('bg-fae8ff', 'color-c026d3');
                                } else {
                                    input.classList.add('bg-red-100', 'text-red-700', 'border-red-500', 'line-through');
                                    input.classList.remove('bg-fae8ff', 'color-c026d3');
                                }
                            });
                            const clearBtn = qItem.querySelector('button[onclick^="clearReorder"]');
                            if (clearBtn) clearBtn.remove();
                            
                            correctDisplay = ex.display_correct_answer || ex.correct_answer.replace(/\|/g, ' / ');
                        }
                    } else {
                        let options = ex.options;
                        const userStr = userAnswers[ex.id];
                        const safeCorrectAns = String(ex.correct_answer || "").trim();
                        
                        isCorrect = (userStr === safeCorrectAns);
                        const correctOpt = options.find(o => String(o.id).trim() === safeCorrectAns);
                        correctDisplay = correctOpt ? correctOpt.text : ex.correct_answer;

                        options.forEach(opt => {
                            const optBtn = document.querySelector(`button[data-qid="${ex.id}"][data-optid="${opt.id}"]`);
                            if (optBtn) {
                                const indicator = optBtn.querySelector('.indicator-circle');
                                if (String(opt.id).trim() === safeCorrectAns) {
                                    optBtn.className = 'option-btn w-full text-left p-3 rounded-xl border-2 bg-bamboo-50 border-bamboo-500 text-bamboo-700 font-bold text-base flex items-center gap-3 shadow-sm';
                                    if (indicator) indicator.className = 'inline-block min-w-[2.5rem] px-3 h-8 rounded-full bg-bamboo-500 text-white flex items-center justify-center border border-bamboo-500 shrink-0 indicator-circle font-bold text-sm';
                                    if (!optBtn.innerHTML.includes('✅')) optBtn.innerHTML += ' <span class="ml-auto text-2xl">✅</span>';
                                } else if (opt.id === userStr && !isCorrect) {
                                    optBtn.className = 'option-btn w-full text-left p-3 rounded-xl border-2 bg-red-50 border-red-500 text-red-700 font-bold text-base flex items-center gap-3 shadow-sm opacity-80';
                                    if (indicator) indicator.className = 'inline-block min-w-[2.5rem] px-3 h-8 rounded-full bg-red-500 text-white flex items-center justify-center border border-red-500 shrink-0 indicator-circle font-bold text-sm';
                                    if (!optBtn.innerHTML.includes('❌')) optBtn.innerHTML += ' <span class="ml-auto text-2xl">❌</span>';
                                }
                            }
                        });
                    }

                    if (feedbackDiv) {
                        feedbackDiv.classList.remove('hidden');
                        if (isCorrect) {
                            score++;
                            qItem.classList.add('border-2', 'border-bamboo-200', 'bg-bamboo-50');
                            qItem.classList.remove('border-slate-200', 'bg-white');
                            feedbackDiv.innerHTML = `<div class="font-extrabold text-bamboo-600 mt-2 flex items-center justify-center bg-white py-2 rounded-xl border border-bamboo-200 shadow-sm text-sm sm:text-base">✨ Chính xác! Đáp án đúng là: <b class="ml-1">${correctDisplay}</b> ✨</div>`;
                        } else {
                            mistakesList.push(ex.exercise_name);
                            qItem.classList.add('border-2', 'border-red-300', 'bg-red-50');
                            qItem.classList.remove('border-slate-200', 'bg-white');
                            feedbackDiv.innerHTML = `
                                <div class="mt-4 bg-sky-50 border-2 border-sky-300 rounded-xl p-4 flex gap-4 items-start shadow-sm relative overflow-hidden">
                                    <div class="text-5xl animate-bounce-gentle z-10">🦉</div>
                                    <div class="w-full z-10">
                                        <h4 class="font-black text-sky-800 text-xl mb-2 border-b border-sky-200 pb-2">Trợ lý Cú Mèo sửa bài:</h4>
                                        <div class="bg-white p-3 rounded-lg font-bold border border-red-200 mb-3 shadow-sm flex flex-wrap items-center gap-2">
                                            <span class="text-red-500 text-2xl">❌</span> 
                                            <span class="text-slate-700">Đáp án đúng phải là:</span> 
                                            <span class="bg-bamboo-100 text-bamboo-700 px-3 py-1 rounded-md border border-bamboo-300 text-lg">${correctDisplay}</span>
                                        </div>
                                        <div class="bg-blue-50 p-3 rounded-lg border border-blue-200">
                                            ${ex.explanation}
                                        </div>
                                    </div>
                                </div>
                            `;
                        }
                    }
                } catch (err) { console.error("Lỗi khi chấm câu:", ex.id, err); }
            });

            const totalQs = exercisesData.length;
            let uniqueMistakes = Array.from(new Set(mistakesList));
            let recommendations = "Xuất sắc! Em đã nắm rất vững kiến thức.";
            if (uniqueMistakes.length > 0) recommendations = "Cần ôn tập lại lý thuyết và cẩn thận hơn ở: " + uniqueMistakes.join(', ') + ".";

            supabaseClient.from('results').insert([{
                student_name: studentName, unit: 'Unit 2: OUR NAMES', exercises_done: 'Đã hoàn thành',
                correct_count: score, incorrect_count: totalQs - score, recommendations: recommendations
            }]).then(({ error }) => { if (error) console.error("Lỗi liên thông:", error); });

            document.getElementById('submit-container').classList.add('hidden');
            document.querySelectorAll('.word-bank-words').forEach(el => el.parentElement.remove());
            localStorage.removeItem(STORAGE_KEY);

            const score10 = ((score / totalQs) * 10).toFixed(1).replace('.0', '');
            document.getElementById('modal-score-10').innerText = score10;
            document.getElementById('modal-correct-score').innerText = score;
            document.getElementById('modal-incorrect-score').innerText = totalQs - score;
            
            const ratio = score / totalQs;
            let message = ""; let emoji = "";
            if (ratio === 1) { message = "Xuất sắc! Điểm tuyệt đối!"; emoji = "🏆"; fireConfetti(); document.getElementById('modal-score-10').className = "text-8xl font-black text-bamboo-600 mb-1"; }
            else if (ratio >= 0.8) { message = "Rất Giỏi!"; emoji = "🌟"; fireConfetti(); document.getElementById('modal-score-10').className = "text-8xl font-black text-bamboo-500 mb-1"; }
            else if (ratio >= 0.5) { message = "Khá lắm, cố gắng thêm nhé!"; emoji = "👍"; document.getElementById('modal-score-10').className = "text-8xl font-black text-sunny-500 mb-1"; document.getElementById('modal-title').className = "text-3xl font-extrabold text-sunny-600 mb-2"; }
            else { message = "Cố gắng lên nhé, đừng nản chí!"; emoji = "💪"; document.getElementById('modal-score-10').className = "text-8xl font-black text-red-500 mb-1"; document.getElementById('modal-title').className = "text-3xl font-extrabold text-red-500 mb-2"; }

            document.getElementById('modal-title').innerText = message; document.getElementById('modal-emoji').innerText = emoji;
            document.getElementById('result-modal').classList.remove('hidden');
            setTimeout(() => { document.getElementById('modal-content').classList.remove('scale-95'); document.getElementById('modal-content').classList.add('scale-100'); }, 10);
        }

        window.closeModal = function() {
            document.getElementById('result-modal').classList.add('hidden');
            document.getElementById('modal-content').classList.remove('scale-100');
            document.getElementById('modal-content').classList.add('scale-95');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function fireConfetti() {
            var duration = 3 * 1000, animationEnd = Date.now() + duration, defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 100 };
            function randomInRange(min, max) { return Math.random() * (max - min) + min; }
            var interval = setInterval(function() {
                var timeLeft = animationEnd - Date.now();
                if (timeLeft <= 0) return clearInterval(interval);
                var particleCount = 50 * (timeLeft / duration);
                confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 } }));
                confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 } }));
            }, 250);
        }

        window.onload = function() { fetchVocabulary(); fetchExercises(); };
    </script>
</body>
</html>
