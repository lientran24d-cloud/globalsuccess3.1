                                qText += ` <span class="text-sunny-500 font-bold">➔</span> <input type="text" id="input-ex-${q.id}-0" data-qid="${q.id}" class="${inputClass} min-w-[150px] w-auto multi-input" placeholder="Viết đáp án..." autocomplete="off" oninput="handleMultiInput('${q.id}')" ${clearEvent}>`; 
