                    // SẮP XẾP CÂU / TỪ (MẢNH GHÉP)
                    else if (exName.includes('Exercise 15') || exName.includes('Exercise 5') || exName.includes('Reorder')) {
                        const words = qText.split('➔')[0].replace(/<br>/g, '').trim().split('/').map(w => w.replace(/^\d+\.\s*/g, '').replace(/[.,?!]/g, '').trim()).filter(w => w !== '');
                        const chipsHtml = words.map((w, wIdx) => `<button type="button" id="reorder-btn-${q.id}-${wIdx}" data-word="${w.replace(/"/g, '&quot;')}" onclick="appendReorderWord('${q.id}', this.getAttribute('data-word'), ${wIdx})" class="reorder-btn-${q.id} bg-blue-50 text-blue-700 hover:bg-blue-200 px-3 py-2 rounded-lg border border-blue-200 font-bold shadow-sm active:scale-95 transition">${w}</button>`).join('');
                        qContent.innerHTML = `${imageHtml}<div class="mb-3 text-sm text-slate-500 italic">Bấm vào các mảnh ghép:</div><div class="flex flex-wrap gap-2 mb-4 p-3 bg-slate-50 rounded-xl border border-slate-200">${chipsHtml}</div><div class="flex items-center gap-2"><span class="text-sunny-500 font-bold text-xl">➔</span> <input type="text" id="input-ex-${q.id}-0" data-qid="${q.id}" class="ex-input w-full text-left px-3 text-blue-700 multi-input" placeholder="Câu hoàn chỉnh..." readonly> <button type="button" onclick="clearReorder('${q.id}')" class="bg-slate-200 text-slate-600 px-3 py-2 rounded-lg font-bold text-sm hover:bg-red-100 hover:text-red-500 shrink-0">Xóa</button></div>`;
                    }
                    // ĐIỀN CHỮ NHIỀU Ô
                    else if (q.question_type === 'input') {
                        const inputClass = q.use_word_bank ? 'ex-input word-bank-target cursor-pointer' : 'ex-input';
                        const clearEvent = q.use_word_bank ? `onclick="if(this.value){this.value=''; handleMultiInput('${q.id}');}" title="Bấm để xóa từ"` : '';
                        let blankCount = 0;

                        if (isEx4) {
                            qText = qText.replace(/___/g, () => { 
                                let idx = blankCount++;
                                return `<input type="text" id="input-ex-${q.id}-${idx}" data-qid="${q.id}" class="${inputClass} text-lg w-24 sm:w-28 multi-input" style="min-width: 110px;" placeholder="..." autocomplete="off" oninput="handleMultiInput('${q.id}')" ${clearEvent}>`; 
