                if (data.length === 0) throw new Error("Chưa có bài tập nào.");

                // Từ điển làm đẹp chữ bị dính liền và định dạng in hoa chuẩn xác
                const formatDictionary = {
                    'seeyouthen': 'See you then!',
                    'howareyou': 'How are you?',
                    'imfine': "I'm fine.",
                    'finethankyou': 'Fine, thank you.',
                    'howfine': "How are you? I'm fine.",
                    'goodbyemsmai': 'Goodbye, Ms. Mai.',
                    'helloimben': "Hello, I'm Ben.",
                    'nicetomeetyou': 'Nice to meet you.',
                    'nicetomeetyoutoo': 'Nice to meet you, too.',
                    'byeclass': 'Bye, class!',
                    'whatsyourname': "What's your name?",
                    'whatisyourname': "What is your name?",
                    'mynameislinda': "My name is Linda.",
                    'mynameslinda': "My name's Linda.",
                    'mynameisphong': "My name is Phong.",
                    'howdoyouspell': "How do you spell your name?",
                    'howdoyouspellyourname': "How do you spell your name?",
                    'howoldareyou': "How old are you?",
                    'imnineyearsold': "I'm nine years old.",
                    'imeightyearsold': "I'm eight years old.",
                    'imsevenyearsold': "I'm seven years old.",
                    'imsixyearsold': "I'm six years old.",
                    'imtenyearsold': "I'm ten years old.",
                    'wearefinethankyou': "We are fine, thank you.",
                    'hellomynameisnam': "Hello. My name is Nam.",
                    'whatishername': "What is her name?",
                    'missmaianhisourenglishteacher': "Miss Mai Anh is our English teacher.",
                    'nicetomeetyouchildren': "Nice to meet you, children.",
                    'hisnameisquan': "His name is Quan.",
                    'howareyoulanandhoa': "How are you, Lan and Hoa?"
                };

                data.forEach(q => {
                    // AUTO FIX TYPO (OCR/AI Lỗi Nhận Diện)
                    if (q.question) {
                        q.question = q.question.replace(/\bhte\b/gi, 'the').replace(/\bform\b/gi, 'from');
                    }
                    if (q.correct_answer) {
                        let rawAns = String(q.correct_answer).trim();
                        rawAns = rawAns.replace(/\bhte\b/gi, 'the').replace(/\bform\b/gi, 'from');
                        
                        // Sửa lỗi nhầm "six" với "see" và ngược lại tùy ngữ cảnh câu hỏi
                        if (rawAns.toLowerCase() === 'six' && q.question.toLowerCase().includes('see you')) {
                            rawAns = 'See';
                        }
                        if (rawAns.toLowerCase() === 'see' && (q.question.toLowerCase().includes('cake') || q.question.toLowerCase().includes('number') || q.question.toLowerCase().includes('tuổi'))) {
                            rawAns = 'six';
                        }
                        
                        q.correct_answer = rawAns;
                    }

                    // ĐỊNH DẠNG ĐÁP ÁN ĐẸP KHÔNG DÍNH LIỀN
                    if (q.question_type === 'input' && q.correct_answer) {
                        if (!q.correct_answer.includes('|')) {
                            let ansLower = String(q.correct_answer).toLowerCase().replace(/[^a-z]/g, '');
                            q.display_correct_answer = formatDictionary[ansLower] || q.correct_answer;
                        } else {
                            q.display_correct_answer = q.correct_answer.replace(/\|/g, ' / ');
                        }
                    }

                    // CHUẨN HÓA TRẮC NGHIỆM
                    if (q.question_type === 'multiple_choice' || q.question_type === 'true_false') {
                        let rawOptions = typeof q.options === 'string' ? JSON.parse(q.options) : q.options;
                        q.options = rawOptions.map((opt, idx) => {
                            let optionId = (q.question_type === 'true_false') ? (idx === 0 ? 'True' : 'False') : String.fromCharCode(65 + idx); 
                            let optLower = (opt.text || opt).toLowerCase().replace(/[^a-z]/g, '');
                            let cleanText = formatDictionary[optLower] ? formatDictionary[optLower] : (opt.text || opt);
                            return { id: optionId, text: cleanText };
                        });
                        
                        if (q.correct_answer) {
                            let rawAns = String(q.correct_answer).replace(/<[^>]*>?/gm, '').trim();
                            let matchedOpt = q.options.find(o => 
                                o.id.toLowerCase() === rawAns.toLowerCase() || 
                                o.text.toLowerCase().includes(rawAns.toLowerCase()) ||
                                (rawAns.toLowerCase() === 'true' && o.text.toLowerCase().includes('đúng')) ||
                                (rawAns.toLowerCase() === 'false' && o.text.toLowerCase().includes('sai')) ||
                                (rawAns.toLowerCase() === 'v' && o.text.toLowerCase().includes('đúng')) ||
                                (rawAns.toLowerCase() === 'x' && o.text.toLowerCase().includes('sai'))
                            );
                            
                            if (matchedOpt) {
                                q.correct_answer = matchedOpt.id; 
                            } else {
                                if (q.question_type === 'multiple_choice') {
                                    let match = rawAns.match(/^([A-E])/i); 
                                    q.correct_answer = match ? match[1].toUpperCase() : rawAns;
                                } else if (q.question_type === 'true_false') {
                                    q.correct_answer = rawAns.toLowerCase().includes('true') ? 'True' : 'False';
                                }
                            }
                        }
                    }

                    // TỰ ĐỘNG SINH GIẢI THÍCH
                    q.explanation = buildDynamicExplanation(q);
                });

                exercisesData = data;
                renderExercisesGrouped(data);
                loadProgress();
            } catch (error) { document.getElementById('loading').innerHTML = `<div class="text-red-500 font-bold text-xl text-center">Lỗi: ${error.message}</div>`; }
        }

        // RENDER GIAO DIỆN
        function renderExercisesGrouped(data) {
            const container = document.getElementById('exercises-container');
            document.getElementById('loading').classList.add('hidden');
            container.classList.remove('hidden');
            document.getElementById('submit-container').classList.remove('hidden');
            document.getElementById('total-questions-display').innerText = data.length;

            let groupedData = {};
            data.forEach(q => {
                let exName = q.exercise_name || "Exercise";
                if (!groupedData[exName]) groupedData[exName] = [];
                groupedData[exName].push(q);
            });

            for (const [exName, questions] of Object.entries(groupedData)) {
                const exBlock = document.createElement('div');
                exBlock.className = 'bg-slate-50 border-2 border-slate-200 p-5 rounded-2xl shadow-sm relative';
                
